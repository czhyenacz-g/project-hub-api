generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OsmaMatchResult {
  id              String   @id @default(cuid())
  homeTeamSlug    String
  homeTeamName    String
  awayTeamSlug    String
  awayTeamName    String
  homeScore       Int
  awayScore       Int
  mode            String   @default("singleplayer")
  durationSeconds Int
  matchComment    String
  playedAt        DateTime
  createdAt       DateTime @default(now())
  onlineMatchId   String?

  @@index([playedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model OsmaOnlineMatch {
  id              String   @id @default(cuid())
  gameCode        String   @unique
  status          String   @default("finished")
  homeTeamSlug    String
  homeTeamName    String
  awayTeamSlug    String
  awayTeamName    String
  homeScore       Int
  awayScore       Int
  winnerSide      String?
  lobbyCreatedAt  DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  durationSeconds Int?
  finishReason    String   @default("full_time")
  publicResultId  String?
  savedAt         DateTime @default(now())
  events          OsmaOnlineMatchEvent[]

  @@index([savedAt(sort: Desc)])
  @@index([gameCode])
}

model OsmaUser {
  id         String   @id @default(cuid())
  discordId  String   @unique
  username   String
  globalName String?
  avatar     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([discordId])
}

model OsmaOnlineMatchEvent {
  id             String          @id @default(cuid())
  onlineMatchId  String
  onlineMatch    OsmaOnlineMatch @relation(fields: [onlineMatchId], references: [id], onDelete: Cascade)
  gameCode       String
  type           String
  matchSecond    Int?
  teamSide       String?
  teamName       String?
  actorLabel     String?
  homeScoreAfter Int?
  awayScoreAfter Int?
  message        String?
  metadataJson   Json?
  createdAt      DateTime @default(now())

  @@index([onlineMatchId])
  @@index([gameCode])
}
