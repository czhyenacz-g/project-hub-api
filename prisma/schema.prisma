generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OsmaMatchResult {
  id              String   @id @default(cuid())
  homeTeamSlug    String
  homeTeamName    String
  awayTeamSlug    String
  awayTeamName    String
  homeScore       Int
  awayScore       Int
  mode            String   @default("singleplayer")
  durationSeconds Int
  matchComment    String
  playedAt        DateTime
  createdAt       DateTime @default(now())
  onlineMatchId   String?

  @@index([playedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model OsmaOnlineMatch {
  id              String   @id @default(cuid())
  gameCode        String   @unique
  status          String   @default("finished")
  homeTeamSlug    String
  homeTeamName    String
  awayTeamSlug    String
  awayTeamName    String
  homeScore       Int
  awayScore       Int
  winnerSide      String?
  lobbyCreatedAt  DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  durationSeconds Int?
  finishReason    String   @default("full_time")
  publicResultId  String?
  savedAt         DateTime @default(now())
  homeUserId      String?
  awayUserId      String?
  homeClubId      String?
  awayClubId      String?
  homeClubPoints  Int?
  awayClubPoints  Int?
  homeUser        OsmaUser?  @relation("HomeUser", fields: [homeUserId], references: [id], onDelete: SetNull)
  awayUser        OsmaUser?  @relation("AwayUser", fields: [awayUserId], references: [id], onDelete: SetNull)
  homeClub        OsmaClub?  @relation("OsmaOnlineMatchHomeClub", fields: [homeClubId], references: [id])
  awayClub        OsmaClub?  @relation("OsmaOnlineMatchAwayClub", fields: [awayClubId], references: [id])
  events          OsmaOnlineMatchEvent[]

  @@index([savedAt(sort: Desc)])
  @@index([gameCode])
  @@index([homeUserId])
  @@index([awayUserId])
  @@index([homeClubId])
  @@index([awayClubId])
}

model OsmaUser {
  id          String   @id @default(cuid())
  discordId   String   @unique
  username    String
  globalName  String?
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  homeMatches OsmaOnlineMatch[] @relation("HomeUser")
  awayMatches OsmaOnlineMatch[] @relation("AwayUser")

  @@index([discordId])
}

model OsmaClub {
  id             String   @id
  slug           String   @unique
  name           String
  shortName      String?
  city           String?
  location       String?
  note           String?
  colors         String?
  motto          String
  description    String
  seasonComment  String?
  banner         String?
  logo           String?
  primaryColor   String?
  secondaryColor String?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  homeOnlineMatches OsmaOnlineMatch[] @relation("OsmaOnlineMatchHomeClub")
  awayOnlineMatches OsmaOnlineMatch[] @relation("OsmaOnlineMatchAwayClub")

  @@index([sortOrder])
  @@index([isActive])
}

model OsmaOnlineMatchEvent {
  id             String          @id @default(cuid())
  onlineMatchId  String
  onlineMatch    OsmaOnlineMatch @relation(fields: [onlineMatchId], references: [id], onDelete: Cascade)
  gameCode       String
  type           String
  matchSecond    Int?
  teamSide       String?
  teamName       String?
  actorLabel     String?
  homeScoreAfter Int?
  awayScoreAfter Int?
  message        String?
  metadataJson   Json?
  createdAt      DateTime @default(now())

  @@index([onlineMatchId])
  @@index([gameCode])
}
