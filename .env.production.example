NODE_ENV=production
PORT=3001

DATABASE_URL=postgresql://project_hub_user:STRONG_RANDOM_PASSWORD@project-hub-postgres:5432/project_hub

PROJECT_HUB_API_KEY=LONG_RANDOM_SECURE_TOKEN_AT_LEAST_32_CHARS

