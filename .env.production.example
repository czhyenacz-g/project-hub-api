TRAINING_CRON_SECRET=LONG_RANDOM_SECURE_TOKEN_AT_LEAST_32_CHARS

CORS_ORIGINS=https://osmaliga.cz,https://www.osmaliga.cz,https://osmaliga.vercel.app
